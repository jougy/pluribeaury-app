---
const { currentPage = 'Descobrir' } = Astro.props;

const items = [
	{ href: '/Descobrir', label: 'Descobrir', key: 'Descobrir', icon: 'compass' },
	{ href: '/Mapa', label: 'Mapa', key: 'Mapa', icon: 'map' },
	{ href: '/Favoritos', label: 'Favoritos', key: 'Favoritos', icon: 'heart' },
	{ href: '/Agenda', label: 'Agenda', key: 'Agenda', icon: 'calendar' },
	{ href: '/Perfil', label: 'Perfil', key: 'Perfil', icon: 'user' },
];

function getIcon(name: string) {
	const icons: Record<string, string> = {
		compass:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"/><path d="m15.9 8.1-2.8 6-6 2.8 2.8-6 6-2.8Z"/></svg>',
		map: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 18 3 20V6l6-2 6 2 6-2v14l-6 2-6-2Z"/><path d="M9 4v14"/><path d="M15 6v14"/></svg>',
		heart:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m12 21-1.4-1.3C5.4 14.8 2 11.7 2 7.9 2 4.8 4.4 2.5 7.4 2.5c1.8 0 3.5.8 4.6 2.1 1.1-1.3 2.8-2.1 4.6-2.1 3 0 5.4 2.3 5.4 5.4 0 3.8-3.4 6.9-8.6 11.8L12 21Z"/></svg>',
		calendar:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 2v4"/><path d="M16 2v4"/><rect x="3" y="4.5" width="18" height="16.5" rx="3"/><path d="M3 9.5h18"/></svg>',
		user: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="8" r="4"/></svg>',
	};

	return icons[name];
}
---

<nav class="bottom-nav" aria-label="Navegação principal">
	<div class="bottom-nav__inner">
		{
			items.map((item) => {
				const isActive = item.key === currentPage;
				return (
					<a class:list={['bottom-nav__item', isActive && 'is-active']} href={item.href}>
						<span class="icon" aria-hidden="true" set:html={getIcon(item.icon)} />
						<span>{item.label}</span>
					</a>
				);
			})
		}
	</div>
</nav>
